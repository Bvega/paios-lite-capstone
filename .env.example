# PAIOS-Lite environment configuration
# Copy this file to .env and fill in your key.
# .env is gitignored — never commit it.

# ── LLM model (LiteLLM format) ──────────────────────────────────────────────
# Pick one provider and supply the matching key below.

LLM_MODEL=gemini/gemini-2.0-flash-exp

# ── Provider keys (supply only the one matching LLM_MODEL) ──────────────────

# Google Gemini (default)
GOOGLE_API_KEY=

# Anthropic Claude (alternative)
# LLM_MODEL=claude-3-5-haiku-20241022
# ANTHROPIC_API_KEY=

# Ollama local model (no key needed)
# LLM_MODEL=ollama/llama3.2
